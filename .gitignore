# Ignore everything by default.
*
.*

# Keep repository-level docs.
!.gitignore
!README.md
!docs/
!docs/**
!scripts/
!scripts/**

# Ignore local agent instructions.
AGENTS.md

# Keep the two deliverable WordPress code directories.
!mydev/
!mydev/wp-content/
!mydev/wp-content/plugins/
!mydev/wp-content/plugins/tharchive-core/
!mydev/wp-content/plugins/tharchive-core/**
!mydev/wp-content/themes/
!mydev/wp-content/themes/tharchive-theme/
!mydev/wp-content/themes/tharchive-theme/**


# Ignore local dependencies and caches inside kept directories.
mydev/wp-content/plugins/tharchive-core/node_modules/
mydev/wp-content/plugins/tharchive-core/node_modules/**
mydev/wp-content/plugins/tharchive-core/.vite/
mydev/wp-content/plugins/tharchive-core/.vite/**

# Ignore Python caches.
scripts/__pycache__/
scripts/__pycache__/**
scripts/*.pyc
scripts/output/
